        // ----------------------------------------CIRCLET IOUN CRIT PROT------------------------------------------------- \\
        OUTER_SET iouncrit_issues = 0

        ACTION_IF zst_1664_crits_all != 0 AND zst_1664_crits_all != 1 BEGIN
            WARN "[WARN]: Setting to make all circlets and ioun stones protect vs. critical hits should be set to 0 (disable) or 1 (enable). Actual value: %zst_1664_crits_all%"
            LAM f_plus
            OUTER_SET iouncrit_issues = 1
        END

        ACTION_IF zst_1664_crits_iouns != 0 AND zst_1664_crits_iouns != 1 BEGIN
            WARN "[WARN]: Setting to make all ioun stones protect vs. critical hits should be set to 0 (disable) or 1 (enable). Actual value: %zst_1664_crits_iouns%"
            LAM f_plus
            OUTER_SET iouncrit_issues = 1
        END

        ACTION_IF zst_1664_crits_circlets != 0 AND zst_1664_crits_circlets != 1 BEGIN
            WARN "[WARN]: Setting to make all circlets protect vs. critical hits should be set to 0 (disable) or 1 (enable). Actual value: %zst_1664_crits_circlets%"
            LAM f_plus
            OUTER_SET iouncrit_issues = 1
        END

        ACTION_IF zst_1664_crits_selected != 0 AND zst_1664_crits_selected != 1 BEGIN
            WARN "[WARN]: Setting to make a selection of  circlets and ioun stones protect vs. critical hits should be set to 0 (disable) or 1 (enable). Actual value: %zst_1664_crits_selected%"
            LAM f_plus
            OUTER_SET iouncrit_issues = 1
        END
        
        ACTION_IF NOT iouncrit_issues BEGIN
            OUTER_SET comb_iouncrit_settings = zst_1664_crits_all + zst_1664_crits_iouns + zst_1664_crits_circlets + zst_1664_crits_selected

            ACTION_IF comb_iouncrit_settings > 1 BEGIN
                WARN "[WARN]: Only one setting in the circlets/ioun protection vs. crits should be set to 1( enable). Actual value: %zst_1664_crits_selected%"
                LAM f_plus
            END ELSE ACTION_IF comb_iouncrit_settings = 0 BEGIN
                WARN "[WARN]: No setting in the circlets/ioun protection vs. crits were picked, leading to no changes by the component One should be set to 1"
                LAM f_plus
            END
        END

