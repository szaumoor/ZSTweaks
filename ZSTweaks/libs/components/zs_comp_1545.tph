    ACTION_IF zst_1545_saving_throws_monk BEGIN
        COPY ~%MOD_FOLDER%/2da/tweaks/SAVEMONK.2DA~ ~override~
        OUTER_SET incl = 1

        ACTION_DEFINE_ASSOCIATIVE_ARRAY death_monk_table BEGIN
            1 => 10  4 => 9  7 => 7  9 =>  6  11 => 5  13 => 4  16 => 3  19 => 2
            2 => 10  5 => 9  8 => 7  10 => 6  12 => 5  14 => 4  17 => 3
            3 => 10  6 => 9                            15 => 4  18 => 3  
        END

        ACTION_DEFINE_ASSOCIATIVE_ARRAY wands_monk_table BEGIN
            1 => 14  4 => 13  7 => 11  9 => 10 10 => 9   13 => 8  16 => 7  19 => 5
            2 => 14  5 => 13  8 => 11          11 => 9   14 => 8  17 => 7
            3 => 14  6 => 13                   12 => 9   15 => 8  18 => 7  
        END

        ACTION_DEFINE_ASSOCIATIVE_ARRAY poly_monk_table BEGIN
            1 => 13  4 => 12  7 => 10  9 => 9  10 => 8   13 => 7  16 => 6  19 => 4
            2 => 13  5 => 12  8 => 10          11 => 8   14 => 7  17 => 6
            3 => 13  6 => 12                   12 => 8   15 => 7  18 => 6  
        END

        ACTION_DEFINE_ASSOCIATIVE_ARRAY breath_monk_table BEGIN
            1 => 16  4 => 15  7 => 13  9 => 12  10 => 10  13 => 9  16 => 7  19 => 6
            2 => 16  5 => 15  8 => 13           11 => 10  14 => 9  17 => 7
            3 => 16  6 => 15                    12 => 10  15 => 9  18 => 7  
        END

        ACTION_DEFINE_ASSOCIATIVE_ARRAY spell_monk_table BEGIN
            1 => 13  4 => 12  7 => 11  9  => 10  11 => 9  12 => 8  15 => 7  19 => 5
            2 => 13  5 => 12  8 => 11  10 => 10           13 => 8  16 => 7 
            3 => 13  6 => 12                              14 => 8  17 => 7   
                                                                   18 => 7
        END
    END

    ACTION_IF zst_1545_saving_throws_patch AND incl BEGIN
        OUTER_SET tolerance = 2

        COPY_EXISTING_REGEXP ~^.+\.cre$~ ~override~
            READ_BYTE 0x271 general
            READ_BYTE 0x273 class
            READ_BYTE 0x234 first_level
            READ_BYTE 0x54 save_death
            READ_BYTE 0x55 save_wands
            READ_BYTE 0x56 save_poly
            READ_BYTE 0x57 save_breath
            READ_BYTE 0x58 save_spell

            PATCH_IF first_level > 0 AND general = general_humanoid BEGIN

                PATCH_IF class = class_thief OR class = class_bard BEGIN

                    SET resolved_level = first_level > 21 ? 21 : first_level
                    PATCH_IF ABS (save_death - $death_rogue_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x54 $death_rogue_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_wands - $wands_rogue_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x55 $wands_rogue_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_poly - $poly_rogue_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x56 $poly_rogue_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_breath - $breath_rogue_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x57 $breath_rogue_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_spell - $spell_rogue_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x58 $spell_rogue_table("%resolved_level%")
                    END                   

                END ELSE PATCH_IF class = class_cleric OR class = class_druid OR class = class_shaman BEGIN

                    SET resolved_level = first_level > 19 ? 19 : first_level
                    PATCH_IF ABS (save_death - $death_priest_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x54 $death_priest_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_wands - $wands_priest_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x55 $wands_priest_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_poly - $poly_priest_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x56 $poly_priest_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_breath - $breath_priest_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x57 $breath_priest_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_spell - $spell_priest_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x58 $spell_priest_table("%resolved_level%")
                    END                   

                END ELSE PATCH_IF class = class_fighter OR class = class_paladin OR class = class_ranger BEGIN

                    SET resolved_level = first_level > 17 ? 17 : first_level
                    PATCH_IF ABS (save_death - $death_warrior_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x54 $death_warrior_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_wands - $wands_warrior_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x55 $wands_warrior_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_poly - $poly_warrior_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x56 $poly_warrior_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_breath - $breath_warrior_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x57 $breath_warrior_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_spell - $spell_warrior_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x58 $spell_warrior_table("%resolved_level%")
                    END  

                END ELSE PATCH_IF class = class_mage OR class = class_sorcerer BEGIN
                    
                    SET resolved_level = first_level > 21 ? 21 : first_level
                    PATCH_IF ABS (save_death - $death_wizard_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x54 $death_wizard_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_wands - $wands_wizard_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x55 $wands_wizard_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_poly - $poly_wizard_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x56 $poly_wizard_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_breath - $breath_wizard_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x57 $breath_wizard_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_spell - $spell_wizard_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x58 $spell_wizard_table("%resolved_level%")
                    END 

                END ELSE PATCH_IF class = class_monk BEGIN

                    SET resolved_level = first_level > 19 ? 19 : first_level
                    PATCH_IF ABS (save_death - $death_monk_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x54 $death_monk_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_wands - $wands_monk_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x55 $wands_monk_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_poly - $poly_monk_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x56 $poly_monk_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_breath - $breath_monk_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x57 $breath_monk_table("%resolved_level%")
                    END

                    PATCH_IF ABS (save_spell - $spell_monk_table("%resolved_level%")) > tolerance BEGIN
                        WRITE_BYTE 0x58 $spell_monk_table("%resolved_level%")
                    END 

                END

            END
                
        BUT_ONLY

    END
        
END
