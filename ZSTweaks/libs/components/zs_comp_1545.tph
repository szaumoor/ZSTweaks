            1 => 13 5 => 11 9  => 9 13 => 8 17 => 6 21 => 5
            2 => 13 6 => 11 10 => 9 14 => 8 18 => 6 
            3 => 13 7 => 11 11 => 9 15 => 8 19 => 6 
            4 => 13 8 => 11 12 => 9 16 => 8 20 => 6
        END

        ACTION_DEFINE_ASSOCIATIVE_ARRAY spell_rogue_table BEGIN
            1 => 16 5 => 14 9  => 12 13 => 10 17 => 8 21 => 6 
            2 => 16 6 => 14 10 => 12 14 => 10 18 => 8 
            3 => 16 7 => 14 11 => 12 15 => 10 19 => 8 
            4 => 16 8 => 14 12 => 12 16 => 10 20 => 8
        END
    END

