ACTION_IF is_bg2ee_or_eet BEGIN

    COPY_EXISTING ~hlolth.itm~ ~override~
        LPF ALTER_ITEM INT_VAR unusable1=0 unusable2=0 unusable3=0 unusable4=0 price=3000 unusable0=4249620484 id_desc=RESOLVE_STR_REF(@60500) END
        LPF ADD_EQUIPPED_EFF STR_VAR effects = ~op=318,res=%SOURCE_RES%,p2=124,p1=18;op=44,p2=1,p1=18~ END

END
